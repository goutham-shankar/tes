# InsightVault — Environment Variables
# Copy this to .env.local  (it is git-ignored by default)

# Optional: Set a default model if you want to override the constant in services/ai/gemini.ts
# NEXT_PUBLIC_GEMINI_TEXT_MODEL=gemini-1.5-flash
# NEXT_PUBLIC_GEMINI_EMBED_MODEL=text-embedding-004

# Note: The actual Gemini API key is NEVER stored here.
# Users provide their own key through the Settings page.
# It is encrypted with AES-GCM and stored in IndexedDB.
